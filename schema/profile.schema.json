{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "current_role",
    "total_years_experience",
    "career_level",
    "employment_history",
    "education",
    "industries",
    "functional_expertise",
    "methods",
    "tools",
    "languages",
    "certifications"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name of the applicant as stated in the CV. If no name can be extracted, set to empty string and the entire profile will be rejected downstream."
    },
    "current_role": {
      "type": [
        "string",
        "null"
      ],
      "description": "Current job title as stated in the CV. Null if applicant is between roles or no current role is identifiable."
    },
    "total_years_experience": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Total years of full-time professional experience, excluding internships and gaps. Mathematically rounded (8.5 -> 9). Null if not derivable."
    },
    "career_level": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "Entry",
        "Mid",
        "Senior",
        "unmapped",
        null
      ],
      "description": "Career level: Entry (0-2 years), Mid (2-4 years), Senior (5+ years). For career-switchers, base on experience in target profession (consulting), not total years."
    },
    "employment_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "employer",
          "role",
          "start_date",
          "end_date",
          "responsibilities"
        ],
        "properties": {
          "employer": {
            "type": "string",
            "description": "Name of the employing organization."
          },
          "role": {
            "type": "string",
            "description": "Job title at this employer."
          },
          "start_date": {
            "type": [
              "string",
              "null"
            ],
            "description": "Start date in ISO 8601 format. Year alone (YYYY), year-month (YYYY-MM), or full date (YYYY-MM-DD) accepted."
          },
          "end_date": {
            "type": [
              "string",
              "null"
            ],
            "description": "End date in ISO 8601 format. Null if position is current."
          },
          "responsibilities": {
            "type": [
              "string",
              "null"
            ],
            "description": "Free-text summary of responsibilities at this role."
          }
        }
      },
      "description": "List of past and current employments. Empty array if no employment history is extractable (e.g., student CVs)."
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "institution",
          "credential",
          "field_of_study",
          "start_date",
          "end_date"
        ],
        "properties": {
          "institution": {
            "type": "string",
            "description": "Name of the educational institution."
          },
          "credential": {
            "type": "string",
            "enum": [
              "PhD",
              "MBA",
              "Executive MBA",
              "Master of Science",
              "Master of Arts",
              "Master of Engineering",
              "Master of Laws (LL.M.)",
              "Bachelor of Science",
              "Bachelor of Arts",
              "Diplom",
              "Staatsexamen",
              "unmapped"
            ],
            "description": "Type of credential. Must map to one entry in the controlled vocabulary. Use 'unmapped' if no mapping is possible."
          },
          "field_of_study": {
            "type": [
              "string",
              "null"
            ],
            "description": "Subject area, e.g., 'Mechanical Engineering', 'Economics'."
          },
          "start_date": {
            "type": [
              "string",
              "null"
            ],
            "description": "Start date as YYYY or YYYY-MM."
          },
          "end_date": {
            "type": [
              "string",
              "null"
            ],
            "description": "End date as YYYY or YYYY-MM."
          }
        }
      },
      "description": "List of educational qualifications. Empty array allowed."
    },
    "industries": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Financial Services",
          "Banking",
          "Insurance",
          "Asset Management",
          "Private Equity",
          "Pharmaceuticals",
          "Healthcare",
          "MedTech",
          "Chemicals",
          "Automotive",
          "Industrial Goods",
          "Energy",
          "Utilities",
          "Consumer Goods",
          "Retail",
          "Telecommunications",
          "Media and Entertainment",
          "Public Sector",
          "Defense",
          "Technology",
          "Software",
          "Logistics and Transportation",
          "unmapped"
        ]
      },
      "description": "Sectors where the applicant has professional experience (including internships). Each entry must map to the controlled vocabulary."
    },
    "functional_expertise": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Strategy",
          "Corporate Strategy",
          "Growth Strategy",
          "Operations",
          "Performance Improvement",
          "Mergers and Acquisitions",
          "Post-Merger Integration",
          "Digital Transformation",
          "Organization Design",
          "Change Management",
          "Marketing and Sales",
          "Supply Chain",
          "Pricing",
          "Procurement",
          "Risk Management",
          "Sustainability",
          "Innovation",
          "unmapped"
        ]
      },
      "description": "Functional areas of operationally performed expertise. Do not derive from related terms, MBA specializations, or industry knowledge alone."
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Lean Six Sigma",
          "Design Thinking",
          "Agile",
          "Scrum",
          "Kanban",
          "Waterfall",
          "SAFe",
          "OKR",
          "Balanced Scorecard",
          "Theory of Constraints",
          "Total Quality Management",
          "BPMN",
          "ITIL",
          "PRINCE2",
          "unmapped"
        ]
      },
      "description": "Methodologies and frameworks the applicant lists."
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Microsoft Excel",
          "Microsoft PowerPoint",
          "Microsoft Word",
          "think-cell",
          "Tableau",
          "Power BI",
          "Alteryx",
          "SAP",
          "Salesforce",
          "Jira",
          "Confluence",
          "SQL",
          "Python",
          "R",
          "unmapped"
        ]
      },
      "description": "Software tools the applicant lists."
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "German (Native)",
          "German (C2)",
          "German (C1)",
          "English (Native)",
          "English (C2)",
          "English (C1)",
          "English (B2)",
          "French (Native)",
          "French (C2)",
          "French (C1)",
          "French (B2)",
          "Spanish (Native)",
          "Spanish (C2)",
          "Spanish (C1)",
          "Spanish (B2)",
          "Italian (Native)",
          "Italian (C2)",
          "Italian (C1)",
          "Italian (B2)",
          "Mandarin (Native)",
          "Mandarin (C2)",
          "Mandarin (C1)",
          "Mandarin (B2)",
          "Portuguese (Native)",
          "Portuguese (C2)",
          "Portuguese (C1)",
          "Portuguese (B2)",
          "unmapped"
        ]
      },
      "description": "Languages with proficiency levels (Native or CEFR B2/C1/C2). German B2 and below are not mapped in v1."
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Free-text completed certifications (e.g., 'CFA Level III', 'PMP'). Exclude 'Candidate' or 'in preparation' status."
    }
  }
}